{{ $linkStr := "\"links\":["}}

{{ $allPages := .Site.AllPages}}
{{ range $i, $allPages }}
{{ $unprocessedRefs := findRESubmatch `\{\{\<ref.*"(.*?)"\>\}\}` $i.RawContent }}
  {{ $refs := slice }} 
  {{ range $u, $unprocessedRefs }}
    {{ $refs = $refs | append (slice (index $u 1))}}
  {{ end }}
  
  {{ range $j, $allPages }}
    {{ if (in $refs (substr $j.RelPermalink 0 -1)) }}
      {{ $linkStr = print $linkStr "{\"source\": \"" $i.Title "\"},"}}
      {{ $linkStr = print $linkStr "{\"target\": \"" $j.Title "\"},"}}
    {{ end }}
  {{ end }}
{{ end }}

{{ $linkStr = substr $linkStr 0 -1 }}
{{ $linkStr = print $linkStr "]"}}

{{ $nodeStr := "\"nodes\":[" }}
{{ range $i, $allPages }}
    {{ $nodeStr = print $nodeStr "{\"name\": \"" $i.Title "\"},"}}
{{ end }}
{{ $nodeStr = substr $nodeStr 0 -1 }}
{{ $nodeStr = print $nodeStr "],"}}

{{ "{" | jsonify}}
{{ $nodeStr | jsonify }}
{{ $linkStr | jsonify }}
{{ "}" | jsonify}}
